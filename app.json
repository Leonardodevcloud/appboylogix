{
  "expo": {
    "name": "Logix Motoboy",
    "slug": "logix-motoboy",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#042C53"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#042C53"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA"
      ]
    },
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Para rastrear sua posi\u00e7\u00e3o durante as entregas.",
        "NSLocationAlwaysUsageDescription": "Para reportar posi\u00e7\u00e3o em segundo plano.",
        "NSCameraUsageDescription": "Para fotografar os comprovantes de entrega."
      }
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera"
    ],
    "scheme": "logix-motoboy"
  }
}